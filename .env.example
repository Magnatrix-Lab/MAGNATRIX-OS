# MAGNATRIX Agentic OS — Environment Configuration

# ====== Core ======
MAGNATRIX_ENV=development
MAGNATRIX_LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here

# ====== Database ======
MAGNATRIX_DB_URL=postgresql://magnatrix:password@localhost:5432/magnatrix
# Fallback untuk development:
# MAGNATRIX_DB_URL=sqlite:///magnatrix.db

# ====== Redis ======
MAGNATRIX_REDIS_URL=redis://localhost:6379/0

# ====== API Providers ======
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
DEEPSEEK_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
COHERE_API_KEY=...
GITHUB_TOKEN=ghp_...

# ====== Cloud ======
HOSTINGER_API_TOKEN=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
GCP_PROJECT_ID=...
AZURE_SUBSCRIPTION_ID=...

# ====== Trading ======
BINANCE_API_KEY=...
BINANCE_SECRET=...

# ====== P2P Mesh ======
MAGNATRIX_NODE_ID=auto
MAGNATRIX_MESH_PORT=8081
MAGNATRIX_BOOTSTRAP_NODES=ws://seed1.magnatrix.io:8081,ws://seed2.magnatrix.io:8081

# ====== Free LLM API (no key needed for most) ======
FREELLM_GROQ_KEY=optional
FREELLM_CEREBRAS_KEY=optional
FREELLM_SAMBANOVA_KEY=optional

# ====== MiniMax (Chinese LLM) ======
MINIMAX_API_KEY=...
MINIMAX_GROUP_ID=...

# ====== Monitoring ======
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin
