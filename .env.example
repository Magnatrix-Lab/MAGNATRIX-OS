# MAGNATRIX Agentic OS — Environment Template
# Copy ke .env dan isi dengan token/token kamu sendiri

# ── Layer 0: Kernel ──
NODE_ENV=production
MAGNATRIX_LOG_LEVEL=info
MAGNATRIX_DATA_DIR=./data
MAGNATRIX_KNOWLEDGE_DIR=./knowledge
MAGNATRIX_LOGS_DIR=./logs

# ── Layer 0.5: Collective Brain ──
KERNEL_URL=http://kernel:3000
PROTOCOL_URL=http://protocol:50051
COLLECTIVE_BRAIN_URL=http://collective-brain:8093

# ── Layer 1.5: API Router ──
API_ROUTER_URL=http://api-router:8080

# ── Layer 2: Identity ──
IDENTITY_URL=http://identity:8081

# ── Layer 3: Runtime ──
RUNTIME_URL=http://runtime:8082

# ── Layer 4: P2P Mesh ──
P2P_URL=http://p2p-mesh:8083

# ── Layer 5: Knowledge ──
KNOWLEDGE_URL=http://knowledge:8084

# ── Layer 6: Skills ──
SKILLS_URL=http://skills:8085

# ── Layer 7: Browser ──
BROWSER_URL=http://browser:8086

# ── Layer 8: Trading ──
TRADING_URL=http://trading:8087
TRADING_MODE=demo
TRADING_REINVESTMENT_RATE=0.30
TRADING_RESERVE_RATE=0.50

# ── Layer 9: Security ──
SECURITY_URL=http://security:8088

# ── Layer 10: Uncensored AI ──
OLLAMA_HOST=http://uncensored:11434
OLLAMA_MODEL=llama3-uncensored

# HuggingFace Token (https://huggingface.co/settings/tokens)
# Untuk download model uncensored lokal
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Layer 11: Governance ──
GOVERNANCE_URL=http://governance:8089
CONSTITUTION_MAX_SHARE=0.30
CONSTITUTION_EMERGENCY_THRESHOLD=0.35

# ── Layer 12: IDE ──
IDE_URL=http://ide:8090

# ── Layer 13: Offensive ──
OFFENSIVE_URL=http://offensive:8091

# ── Layer 13.5: Auto Repo Hunter ──
HUNTER_URL=http://hunter:8092

# ── Hostinger Cloud (https://hpanel.hostinger.com/api) ──
# Untuk deploy MAGNATRIX nodes ke cloud VPS
HOSTINGER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Web Dashboard ──
DASHBOARD_URL=http://localhost:8095

# ── Chat Bridge ──
CHAT_WS_URL=ws://localhost:8765

# ── Free LLM Providers (FreeLLMAPI Integration) ──
# Dapatkan API key gratis dari provider berikut:
# Google AI Studio : https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Groq            : https://console.groq.com/keys
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Cerebras        : https://cloud.cerebras.ai/
CEREBRAS_API_KEY=csk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# SambaNova       : https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Mistral         : https://console.mistral.ai/
MISTRAL_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# OpenRouter      : https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXX
# GitHub PAT      : https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Cloudflare      : https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CF_ACCOUNT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Cohere          : https://dashboard.cohere.com/api-keys
COHERE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Z.ai (Zhipu)    : https://open.bigmodel.cn/
ZAI_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# NVIDIA          : https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXXXXXXXXXXX
